{
  "version": "0.0.1",
  "architecture": {
    "framework": "Python Flask",
    "orm": "SQLAlchemy",
    "database": "SQLite (data/app.db)",
    "auth": "Flask-Login session management + bcrypt password hashing",
    "frontend": "Jinja2 templates + Bootstrap 5 CSS (CDN)",
    "base_path": "/projects/contract-mgmt-v2/",
    "port": 19051,
    "static_version_token": "?v=0.0.1",
    "cache_control": "Cache-Control: no-cache on all HTML responses",
    "file_upload": {
      "allowed_extensions": ["pdf", "doc", "docx"],
      "max_size_bytes": 10485760,
      "max_size_mb": 10,
      "storage": "local filesystem (uploads/)"
    },
    "app_structure": {
      "entry_point": "app.py",
      "blueprint": "main_bp with url_prefix=/projects/contract-mgmt-v2",
      "middleware": "after_request hook injecting Cache-Control: no-cache for HTML responses"
    }
  },
  "data_models": {
    "User": {
      "table": "users",
      "columns": {
        "id": "INTEGER PRIMARY KEY AUTOINCREMENT",
        "username": "VARCHAR(80) UNIQUE NOT NULL",
        "password_hash": "VARCHAR(255) NOT NULL",
        "role": "VARCHAR(20) NOT NULL DEFAULT 'user'",
        "is_active": "BOOLEAN NOT NULL DEFAULT 1",
        "created_at": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP"
      },
      "roles": ["admin", "user"],
      "preset_accounts": [
        {"username": "admin", "password": "admin123", "role": "admin"},
        {"username": "demo", "password": "demo123", "role": "user"}
      ]
    },
    "Contract": {
      "table": "contracts",
      "columns": {
        "id": "INTEGER PRIMARY KEY AUTOINCREMENT",
        "title": "VARCHAR(200) NOT NULL",
        "description": "TEXT",
        "counterparty": "VARCHAR(200) NOT NULL",
        "amount": "DECIMAL(15,2)",
        "status": "VARCHAR(50) NOT NULL DEFAULT 'draft'",
        "user_id": "INTEGER NOT NULL FOREIGN KEY -> users.id",
        "created_at": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP",
        "updated_at": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP"
      },
      "statuses": ["draft", "active", "completed", "terminated"]
    },
    "Attachment": {
      "table": "attachments",
      "columns": {
        "id": "INTEGER PRIMARY KEY AUTOINCREMENT",
        "filename": "VARCHAR(255) NOT NULL",
        "original_filename": "VARCHAR(255) NOT NULL",
        "file_path": "VARCHAR(500) NOT NULL",
        "file_size": "INTEGER NOT NULL",
        "mime_type": "VARCHAR(100) NOT NULL",
        "contract_id": "INTEGER NOT NULL FOREIGN KEY -> contracts.id ON DELETE CASCADE",
        "uploaded_at": "DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP"
      }
    }
  },
  "routes": {
    "auth": [
      {"method": "GET|POST", "path": "/auth/login", "handler": "login", "auth": "public"},
      {"method": "GET|POST", "path": "/auth/register", "handler": "register", "auth": "public"},
      {"method": "GET", "path": "/auth/logout", "handler": "logout", "auth": "login_required"}
    ],
    "contracts": [
      {"method": "GET", "path": "/", "handler": "dashboard", "auth": "login_required", "description": "合同列表/首页"},
      {"method": "GET|POST", "path": "/contracts/create", "handler": "contract_create", "auth": "login_required"},
      {"method": "GET", "path": "/contracts/<id>", "handler": "contract_detail", "auth": "login_required"},
      {"method": "GET|POST", "path": "/contracts/<id>/edit", "handler": "contract_edit", "auth": "login_required"},
      {"method": "POST", "path": "/contracts/<id>/delete", "handler": "contract_delete", "auth": "login_required"},
      {"method": "POST", "path": "/contracts/<id>/attachments/upload", "handler": "attachment_upload", "auth": "login_required"},
      {"method": "GET", "path": "/attachments/<id>/download", "handler": "attachment_download", "auth": "login_required"}
    ],
    "admin": [
      {"method": "GET", "path": "/admin/users", "handler": "admin_users", "auth": "admin_required"},
      {"method": "POST", "path": "/admin/users/<id>/toggle", "handler": "admin_user_toggle", "auth": "admin_required"},
      {"method": "POST", "path": "/admin/users/<id>/delete", "handler": "admin_user_delete", "auth": "admin_required"}
    ],
    "system": [
      {"method": "GET", "path": "/healthz", "handler": "healthz", "auth": "public"}
    ]
  },
  "pages": [
    {"name": "base.html", "description": "基础布局模板，包含导航栏、flash 消息、Bootstrap 5 CDN、响应式布局"},
    {"name": "login.html", "description": "登录页面，用户名+密码表单"},
    {"name": "register.html", "description": "注册页面，用户名+密码+确认密码表单"},
    {"name": "dashboard.html", "description": "合同列表仪表盘，显示当前用户的合同列表，管理员可查看所有"},
    {"name": "contract_detail.html", "description": "合同详情页，显示合同信息和附件列表，提供下载和上传操作"},
    {"name": "contract_form.html", "description": "合同创建/编辑表单，支持附件上传"},
    {"name": "admin_users.html", "description": "管理员用户管理页面，用户列表，支持禁用/启用和删除操作"}
  ],
  "file_structure": {
    "root": "/Users/chenqingwei/外部需求/proj-ebbd9e",
    "key_files": [
      {"path": "app.py", "purpose": "Flask 应用入口，蓝图注册，数据库初始化，启动配置"},
      {"path": "models.py", "purpose": "SQLAlchemy 模型定义 (User, Contract, Attachment)"},
      {"path": "config.py", "purpose": "应用配置类（数据库 URI、密钥、上传限制等）"},
      {"path": "init_db.py", "purpose": "数据库初始化脚本，创建表并预置管理员/普通用户账号"},
      {"path": "requirements.txt", "purpose": "Python 依赖清单"},
      {"path": "templates/", "purpose": "Jinja2 模板目录"},
      {"path": "static/css/style.css", "purpose": "自定义样式"},
      {"path": "uploads/", "purpose": "上传附件存储目录"}
    ]
  }
}
